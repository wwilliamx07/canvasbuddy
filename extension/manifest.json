{
  "manifest_version": 3,
  "name": "CanvasBuddy",
  "version": "0.0.0",
  "description": "AI study assistant for Canvas",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "logo128.png",
      "48": "logo128.png",
      "128": "logo128.png"
    }
  },
  "icons": {
    "16": "logo128.png",
    "48": "logo128.png",
    "128": "logo128.png"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://*.utoronto.ca/*"
  ]
}